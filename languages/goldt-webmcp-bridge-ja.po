# Translation file
msgid ""
msgstr ""
"Content-Type: text/plain; charset=UTF-8\n"
"Language: ja
"Content-Transfer-Encoding: 8bit\n"

msgid "GoldT WebMCP Bridge"
msgstr "GoldT WebMCP ブリッジ"

msgid "Bridge for 8 AI agents (Claude, ChatGPT, Grok, more) via WebMCP with OAuth 2.0"
msgstr "OAuth 2.0 を使用した WebMCP 経由の 8 つの AI エージェント (Claude、ChatGPT、Grok など) のブリッジ"

msgid "chgold"
msgstr "chgold"

msgid "https://github.com/chgold"
msgstr "https://github.com/chgold"

msgid "GoldT WebMCP Bridge: Missing dependencies. Please run \"composer install\" in the plugin directory."
msgstr "GoldT WebMCP Bridge: 依存関係が見つかりません。プラグインディレクトリで「composer install」を実行してください。"

msgid "GoldT WebMCP Bridge: WooCommerce is recommended for full functionality."
msgstr "GoldT WebMCP Bridge: 完全な機能を利用するには WooCommerce が推奨されます。"

msgid "Settings"
msgstr "設定"

msgid "AI Connect"
msgstr "AIコネクト"

msgid "✅ AI Connect v%s is active and ready!"
msgstr "✅ AI Connect v %sがアクティブになり、準備が整いました！"

msgid "Environment Status"
msgstr "環境ステータス"

msgid "Dependencies Missing"
msgstr "依存関係がありません"

msgid "Run the following command in the plugin directory:"
msgstr "プラグイン ディレクトリで次のコマンドを実行します。"

msgid "User access revoked successfully."
msgstr "ユーザーアクセスが正常に取り消されました。"

msgid "User access restored successfully."
msgstr "ユーザーアクセスが正常に復元されました。"

msgid "JWT Secret rotated successfully! All existing tokens have been invalidated."
msgstr "JWTシークレットのローテーションに成功しました！既存のトークンはすべて無効になりました。"

msgid "Settings saved!"
msgstr "設定を保存しました!"

msgid "API Rate Limiting"
msgstr "レート制限"

msgid "Rate Limit (per minute)"
msgstr "レート制限（ 1分あたり）"

msgid "Maximum API requests per minute per user"
msgstr "ユーザーごとの1分あたりの最大APIリクエスト数"

msgid "Rate Limit (per hour)"
msgstr "レート制限（ 1時間あたり）"

msgid "Maximum API requests per hour per user"
msgstr "ユーザーごとの1時間あたりの最大APIリクエスト数"

msgid "Data Management"
msgstr "データ管理"

msgid "Uninstall Cleanup"
msgstr "クリーンアップのアンインストール"

msgid "Delete all plugin data when uninstalling"
msgstr "アンインストール時にすべてのプラグインデータを削除する"

msgid "When enabled, all OAuth clients, tokens, and settings will be permanently deleted when you uninstall this plugin. Leave unchecked to preserve data for reinstallation."
msgstr "有効にすると、このプラグインをアンインストールすると、すべてのOAuthクライアント、トークン、および設定が完全に削除されます。再インストールのためにデータを保持するには、チェックを外したままにしてください。"

msgid "Note:"
msgstr "注意:"

msgid "Sensitive security data (JWT secrets, refresh tokens) will always be deleted regardless of this setting."
msgstr "機密性の高いセキュリティデータ（ JWTシークレット、リフレッシュトークン）は、この設定に関係なく常に削除されます。"

msgid "Save Settings"
msgstr "設定を保存"

msgid "Security"
msgstr "セキュリティ"

msgid "Rotate JWT Secret Key"
msgstr "JWTシークレットキーを回転"

msgid "This will generate a new JWT secret key and <strong>immediately invalidate all existing access tokens</strong>."
msgstr "これにより、新しいJWT秘密鍵が生成され、<strong>既存のすべてのアクセストークンが直ちに無効になり</strong>ます。"

msgid "All users will need to authenticate again to get new tokens."
msgstr "新しいトークンを取得するには、すべてのユーザーが再度認証する必要があります。"

msgid "Warning:"
msgstr "警告:"

msgid "This action cannot be undone. All AI agents currently connected will be disconnected."
msgstr "この操作は元に戻せません。現在接続されているすべてのAIエージェントは切断されます。"

msgid "Are you sure you want to rotate the JWT secret? This will disconnect all connected AI agents and users will need to re-authenticate."
msgstr "JWTシークレットを回転してもよろしいですか？これにより、接続されているすべてのAIエージェントが切断され、ユーザーは再認証する必要があります。"

msgid "Rotate JWT Secret"
msgstr "JWTシークレットを回転"

msgid "Manage User Access"
msgstr "ユーザーアクセスの管理"

msgid "Block specific users from accessing AI Connect. Blocked users cannot authenticate or use existing tokens."
msgstr "特定のユーザーがAI Connectにアクセスするのをブロックします。ブロックされたユーザーは、既存のトークンを認証または使用できません。"

msgid "Blocked Users"
msgstr "ブロックしたユーザー"

msgid "User ID"
msgstr "ユーザーID"

msgid "Username"
msgstr "ユーザー名"

msgid "Email"
msgstr "メール"

msgid "Action"
msgstr "操作"

msgid "Restore Access"
msgstr "アクセスを復元"

msgid "No users are currently blocked."
msgstr "現在ブロックされているユーザーはいません。"

msgid "Block a User"
msgstr "ユーザーをブロックする"

msgid "User ID:"
msgstr "ユーザーID:"

msgid "Enter the WordPress user ID to block"
msgstr "ブロックするWordPressユーザーIDを入力してください"

msgid "Block User"
msgstr "ユーザーをブロック"

msgid "OAuth Tokens"
msgstr "OAuthトークン"

msgid "Token revoked successfully."
msgstr "トークンは正常に取り消されました。"

msgid "Read content"
msgstr "コンテンツを読む"

msgid "Read posts, pages, and other content"
msgstr "投稿、ページ、その他のコンテンツを読む"

msgid "Write content"
msgstr "コンテンツを書く"

msgid "Create and update posts and pages"
msgstr "投稿やページの作成と更新"

msgid "Delete content"
msgstr "コンテンツを削除する"

msgid "Delete posts and pages"
msgstr "投稿とページを削除する"

msgid "Manage users"
msgstr "ユーザーの管理"

msgid "View and manage user accounts"
msgstr "ユーザーアカウントの表示と管理"

msgid "OAuth Access Tokens"
msgstr "OAuth アクセストークン"

msgid "Manage OAuth access tokens that have been granted to AI applications."
msgstr "AI アプリケーションに付与された OAuth アクセス トークンを管理します。"

msgid "Client"
msgstr "クライアント"

msgid "User"
msgstr "ユーザー"

msgid "Scopes"
msgstr "スコープ"

msgid "Created"
msgstr "作成"

msgid "Access Token Expires"
msgstr "アクセストークンの有効期限"

msgid "Refresh Token Expires"
msgstr "リフレッシュトークンの有効期限"

msgid "Actions"
msgstr "アクション"

msgid "No active tokens found."
msgstr "アクティブなトークンが見つかりません。"

msgid "Expired"
msgstr "期限切れ"

msgid "N/A"
msgstr "該当なし"

msgid "Are you sure you want to revoke this token?"
msgstr "このトークンを取り消してもよろしいですか?"

msgid "Revoke"
msgstr "取り消す"

msgid "Authorization Request"
msgstr "承認リクエスト"

msgid "is requesting access to your account"
msgstr "あなたのアカウントへのアクセスを要求しています"

msgid "This will allow the application to:"
msgstr "これにより、アプリケーションは次のことが可能になります。"

msgid "Deny"
msgstr "拒否"

msgid "Approve"
msgstr "承認する"

msgid "Only approve if you trust this application. It will have access to your account data based on the permissions above."
msgstr "このアプリケーションを信頼できる場合のみ承認してください。上記の権限に基づいて、アプリケーションはあなたのアカウントデータにアクセスできるようになります。"

msgid "Read your posts and content"
msgstr "投稿やコンテンツを読む"

msgid "Create and modify posts"
msgstr "投稿の作成と変更"

msgid "Delete posts"
msgstr "投稿を削除する"

msgid "Authorization Successful"
msgstr "認証成功"

msgid "Copy this authorization code and paste it back to the AI application:"
msgstr "この認証コードをコピーして、AI アプリケーションに貼り付けます。"

msgid "Authorization Code"
msgstr "承認コード"

msgid "Copy Code"
msgstr "コードをコピー"

msgid "Code copied to clipboard!"
msgstr "コードがクリップボードにコピーされました。"

msgid "Important:"
msgstr "重要："

msgid "This code expires in 10 minutes and can only be used once."
msgstr "このコードは 10 分で有効期限が切れ、1 回しか使用できません。"

