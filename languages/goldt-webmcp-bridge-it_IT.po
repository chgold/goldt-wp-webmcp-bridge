msgid "AI Connect"
msgstr "AI Connect"

msgid "https://github.com/chgold/goldt-webmcp-bridge"
msgstr "https://github.com/chgold/goldt-webmcp-bridge"

msgid "Bridge WordPress & AI Agents with WebMCP Protocol"
msgstr "Collega gli agenti WordPress e AI con il protocollo WebMCP"

msgid "chgold"
msgstr "chgold"

msgid "https://github.com/chgold"
msgstr "https://github.com/chgold"

msgid "AI Connect: Missing dependencies. Please run \\"composer install\\" in the plugin directory."
msgstr "AI Connect: dipendenze mancanti. Eseguire \\"composer install\\" nella directory del plugin."

msgid "AI Connect: WooCommerce is recommended for full functionality."
msgstr "AI Connect: WooCommerce è consigliato per la piena funzionalità."

msgid "Settings"
msgstr "Impostazioni"

msgid "✅ AI Connect v%s is active and ready!"
msgstr "✅ AI Connect v%s è attivo e pronto!"

msgid "Environment Status"
msgstr "Stato dell'ambiente"

msgid "⚠️ Action Required"
msgstr "Azione richiesta"

msgid "Composer dependencies are not installed. Please run:"
msgstr "Le dipendenze del compositore non sono installate. Eseguire:"

msgid "🎯 Quick Start"
msgstr "Avvio rapido"

msgid "Test the API"
msgstr "Testare l'API"

msgid "View Manifest"
msgstr "Visualizza manifesto"

msgid "Authentication"
msgstr "Autenticazione"

msgid "Use WordPress username & password to login via"
msgstr "Usa il nome utente e la password di WordPress per accedere tramite"

msgid "Available Tools"
msgstr "Strumenti disponibili"

msgid "5 WordPress core tools (searchPosts, getPost, searchPages, getPage, getCurrentUser)"
msgstr "5 strumenti principali di WordPress (searchPosts, getPost, searchPages, getPage, getCurrentUser)"

msgid "Documentation"
msgstr "Documentazione"

msgid "GitHub README"
msgstr "GitHub README"

msgid "User access revoked successfully."
msgstr "Accesso utente revocato correttamente."

msgid "User access restored successfully."
msgstr "Accesso utente ripristinato correttamente."

msgid "JWT Secret rotated successfully! All existing tokens have been invalidated."
msgstr "JWT Secret ruotato con successo! Tutti i token esistenti sono stati invalidati."

msgid "Settings saved!"
msgstr "Impostazioni salvate."

msgid "API Rate Limiting"
msgstr "Limite di tasso"

msgid "Rate Limit (per minute)"
msgstr "Limite di velocità (al minuto)"

msgid "Maximum API requests per minute per user"
msgstr "Numero massimo di richieste API al minuto per utente"

msgid "Rate Limit (per hour)"
msgstr "Limite di tariffa (all'ora)"

msgid "Maximum API requests per hour per user"
msgstr "Numero massimo di richieste API all'ora per utente"

msgid "Data Management"
msgstr "Gestione dei dati"

msgid "Uninstall Cleanup"
msgstr "Disinstalla Pulizia"

msgid "Delete all plugin data when uninstalling"
msgstr "Elimina tutti i dati del plugin durante la disinstallazione"

msgid "When enabled, all OAuth clients, tokens, and settings will be permanently deleted when you uninstall this plugin. Leave unchecked to preserve data for reinstallation."
msgstr "Se abilitato, tutti i client OAuth, i token e le impostazioni verranno eliminati definitivamente quando si disinstalla questo plugin. Lasciare deselezionato per conservare i dati per la reinstallazione."

msgid "Note:"
msgstr "Nota:"

msgid "Sensitive security data (JWT secrets, refresh tokens) will always be deleted regardless of this setting."
msgstr "I dati di sicurezza sensibili (segreti JWT, token di aggiornamento) verranno sempre eliminati indipendentemente da questa impostazione."

msgid "Save Settings"
msgstr "Salva Impostazioni"

msgid "Security"
msgstr "Sicurezza"

msgid "Rotate JWT Secret Key"
msgstr "Ruota la chiave segreta JWT"

msgid "This will generate a new JWT secret key and <strong>immediately invalidate all existing access tokens</strong>."
msgstr "Questo genererà una nuova chiave segreta JWT e <strong>invaliderà immediatamente tutti i token di accesso esistenti</strong>."

msgid "All users will need to authenticate again to get new tokens."
msgstr "Tutti gli utenti dovranno autenticarsi di nuovo per ottenere nuovi token."

msgid "Warning:"
msgstr "Attenzione:"

msgid "This action cannot be undone. All AI agents currently connected will be disconnected."
msgstr "Questa azione non può essere annullata. Tutti gli agenti AI attualmente connessi verranno disconnessi."

msgid "Are you sure you want to rotate the JWT secret? This will disconnect all connected AI agents and users will need to re-authenticate."
msgstr "Sei sicuro di voler ruotare il segreto JWT? Questo disconnetterà tutti gli agenti di intelligenza artificiale connessi e gli utenti dovranno autenticarsi nuovamente."

msgid "Rotate JWT Secret"
msgstr "Ruota JWT Secret"

msgid "Manage User Access"
msgstr "Gestisci l'accesso degli utenti"

msgid "Block specific users from accessing AI Connect. Blocked users cannot authenticate or use existing tokens."
msgstr "Impedisci a utenti specifici di accedere a AI Connect. Gli utenti bloccati non possono autenticarsi o utilizzare i token esistenti."

msgid "Blocked Users"
msgstr "Utenti bloccati"

msgid "User ID"
msgstr "Codice utente"

msgid "Username"
msgstr "Username"

msgid "Email"
msgstr "E-mail"

msgid "Action"
msgstr "Action"

msgid "Restore Access"
msgstr "Ripristina accesso"

msgid "No users are currently blocked."
msgstr "Nessun utente è attualmente bloccato."

msgid "Block a User"
msgstr "Blocca un utente"

msgid "User ID:"
msgstr "ID utente:"

msgid "Enter the WordPress user ID to block"
msgstr "Inserisci l'ID utente WordPress da bloccare"

msgid "Block User"
msgstr "Blocca utente"

