msgstr "Niet van toepassing"

msgid "Are you sure you want to revoke this token?"
msgstr "Weet je zeker dat je dit token wilt intrekken?"

msgid "Revoke"
msgstr "Herroepen"

msgid "Authorization Request"
msgstr "Autorisatieverzoek"

msgid "is requesting access to your account"
msgstr "verzoekt om toegang tot uw account"

msgid "This will allow the application to:"
msgstr "Dit stelt de applicatie in staat om:"

msgid "Deny"
msgstr "Ontkennen"

msgid "Approve"
msgstr "Goedkeuren"

msgid "Only approve if you trust this application. It will have access to your account data based on the permissions above."
msgstr "Ga alleen akkoord als u deze applicatie vertrouwt. De applicatie krijgt toegang tot uw accountgegevens op basis van de hierboven vermelde machtigingen."

msgid "Read your posts and content"
msgstr "Ik lees je berichten en content."

msgid "Create and modify posts"
msgstr "Berichten maken en bewerken"

msgid "Delete posts"
msgstr "Berichten verwijderen"

