msgstr "Berichten en pagina's maken en bijwerken"

msgid "Delete content"
msgstr "Inhoud verwijderen"

msgid "Delete posts and pages"
msgstr "Berichten en pagina's verwijderen"

msgid "Manage users"
msgstr "Gebruikers beheren"

msgid "View and manage user accounts"
msgstr "Gebruikersaccounts bekijken en beheren"

msgid "OAuth Access Tokens"
msgstr "OAuth-toegangstokens"

msgid "Manage OAuth access tokens that have been granted to AI applications."
msgstr "Beheer de OAuth-toegangstokens die aan AI-toepassingen zijn verleend."

