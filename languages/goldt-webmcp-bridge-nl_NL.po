msgstr "Autorisatiecode"

msgid "Copy Code"
msgstr "Kopieer code"

msgid "Code copied to clipboard!"
msgstr "Code gekopieerd naar het klembord!"

msgid "Important:"
msgstr "Belangrijk:"

msgid "This code expires in 10 minutes and can only be used once."
msgstr "Deze code is 10 minuten geldig en kan slechts één keer gebruikt worden."

