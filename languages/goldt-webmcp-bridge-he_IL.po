# Translation file
msgid ""
msgstr ""
"Content-Type: text/plain; charset=UTF-8\n"
"Content-Transfer-Encoding: 8bit\n"

msgid "GoldT WebMCP Bridge"
msgstr "גשר WebMCP של GoldT"

msgid "Bridge for 8 AI agents (Claude, ChatGPT, Grok, more) via WebMCP with OAuth 2.0"
msgstr "גשר עבור 8 סוכני בינה מלאכותית (Claude, ChatGPT, Grok ועוד) דרך WebMCP עם OAuth 2.0"

msgid "chgold"
msgstr "chgold"

msgid "https://github.com/chgold"
msgstr "https://github.com/chgold"

msgid "GoldT WebMCP Bridge: Missing dependencies. Please run \"composer install\" in the plugin directory."
msgstr "גשר WebMCP של GoldT: תלויות חסרות. אנא הפעל את \"composer install\" בספריית התוספים."

msgid "GoldT WebMCP Bridge: WooCommerce is recommended for full functionality."
msgstr "גשר WebMCP של GoldT: מומלץ להשתמש ב-WooCommerce לפונקציונליות מלאה."

msgid "Settings"
msgstr "הגדרות"

msgid "AI Connect"
msgstr "בינה מלאכותית קונקט"

msgid "✅ AI Connect v%s is active and ready!"
msgstr "✅ AI Connect v%s פעיל ומוכן!"

msgid "Environment Status"
msgstr "מצב סביבתי"

msgid "Dependencies Missing"
msgstr "תלויות חסרות"

msgid "Run the following command in the plugin directory:"
msgstr "הפעל את הפקודה הבאה בספריית התוסף:"

msgid "User access revoked successfully."
msgstr "גישת המשתמש בוטלה בהצלחה."

msgid "User access restored successfully."
msgstr "גישת המשתמש שוחזרה בהצלחה."

msgid "JWT Secret rotated successfully! All existing tokens have been invalidated."
msgstr "סוד JWT הסתובב בהצלחה! כל האסימונים הקיימים בוטלו."

msgid "Settings saved!"
msgstr "ההגדרות נשמרו!"

msgid "API Rate Limiting"
msgstr "הגבלת קצב API"

msgid "Rate Limit (per minute)"
msgstr "מגבלת קצב (לדקה)"

msgid "Maximum API requests per minute per user"
msgstr "מקסימום בקשות API לדקה למשתמש"

msgid "Rate Limit (per hour)"
msgstr "מגבלת תעריף (לשעה)"

msgid "Maximum API requests per hour per user"
msgstr "מקסימום בקשות API לשעה למשתמש"

msgid "Data Management"
msgstr "ניהול נתונים"

msgid "Uninstall Cleanup"
msgstr "ניקוי ההתקנה"

msgid "Delete all plugin data when uninstalling"
msgstr "מחיקת כל נתוני התוסף בעת הסרת ההתקנה"

msgid "When enabled, all OAuth clients, tokens, and settings will be permanently deleted when you uninstall this plugin. Leave unchecked to preserve data for reinstallation."
msgstr "כאשר אפשרות זו מופעלת, כל לקוחות, טוקנים והגדרות OAuth יימחקו לצמיתות לאחר הסרת התוסף. השאר את האפשרות לא מסומנת כדי לשמור נתונים להתקנה מחדש."

msgid "Note:"
msgstr "פֶּתֶק:"

msgid "Sensitive security data (JWT secrets, refresh tokens) will always be deleted regardless of this setting."
msgstr "נתוני אבטחה רגישים (סודות JWT, אסימוני רענון) יימחקו תמיד ללא קשר להגדרה זו."

msgid "Save Settings"
msgstr "שמור הגדרות"

msgid "Security"
msgstr "בִּטָחוֹן"

msgid "Rotate JWT Secret Key"
msgstr "סיבוב מפתח סודי של JWT"

msgid "This will generate a new JWT secret key and <strong>immediately invalidate all existing access tokens</strong>."
msgstr "פעולה זו תיצור מפתח סודי JWT חדש ותבטל <strong>באופן מיידי את כל אסימוני הגישה הקיימים</strong> ."

msgid "All users will need to authenticate again to get new tokens."
msgstr "כל המשתמשים יצטרכו לאמת שוב כדי לקבל אסימונים חדשים."

msgid "Warning:"
msgstr "אַזהָרָה:"

msgid "This action cannot be undone. All AI agents currently connected will be disconnected."
msgstr "לא ניתן לבטל פעולה זו. כל סוכני הבינה המלאכותית המחוברים כעת ינותקו."

msgid "Are you sure you want to rotate the JWT secret? This will disconnect all connected AI agents and users will need to re-authenticate."
msgstr "האם אתה בטוח שברצונך לסובב את סוד ה-JWT? פעולה זו תנתק את כל סוכני הבינה המלאכותית המחוברים והמשתמשים יצטרכו לאמת מחדש."

msgid "Rotate JWT Secret"
msgstr "סובב את סוד JWT"

msgid "Manage User Access"
msgstr "ניהול גישת משתמש"

msgid "Block specific users from accessing AI Connect. Blocked users cannot authenticate or use existing tokens."
msgstr "חסום משתמשים ספציפיים מגישה ל-AI Connect. משתמשים חסומים אינם יכולים לאמת או להשתמש באסימונים קיימים."

msgid "Blocked Users"
msgstr "משתמשים חסומים"

msgid "User ID"
msgstr "מזהה משתמש"

msgid "Username"
msgstr "שם משתמש"

msgid "Email"
msgstr "אֶלֶקטרוֹנִי"

msgid "Action"
msgstr "פְּעוּלָה"

msgid "Restore Access"
msgstr "שחזור גישה"

msgid "No users are currently blocked."
msgstr "אין משתמשים חסומים כרגע."

msgid "Block a User"
msgstr "חסימת משתמש"

msgid "User ID:"
msgstr "מזהה משתמש:"

msgid "Enter the WordPress user ID to block"
msgstr "הזן את שם המשתמש של WordPress כדי לחסום"

msgid "Block User"
msgstr "חסימת משתמש"

msgid "OAuth Tokens"
msgstr "אסימוני OAuth"

msgid "Token revoked successfully."
msgstr "האסימון בוטל בהצלחה."

msgid "Read content"
msgstr "קרא תוכן"

msgid "Read posts, pages, and other content"
msgstr "קריאת פוסטים, דפים ותוכן אחר"

msgid "Write content"
msgstr "כתיבת תוכן"

msgid "Create and update posts and pages"
msgstr "יצירה ועדכון של פוסטים ודפים"

msgid "Delete content"
msgstr "מחיקת תוכן"

msgid "Delete posts and pages"
msgstr "מחיקת פוסטים ודפים"

msgid "Manage users"
msgstr "ניהול משתמשים"

msgid "View and manage user accounts"
msgstr "הצג ונהל חשבונות משתמשים"

msgid "OAuth Access Tokens"
msgstr "אסימוני גישה של OAuth"

msgid "Manage OAuth access tokens that have been granted to AI applications."
msgstr "ניהול אסימוני גישה של OAuth שהוענקו ליישומי בינה מלאכותית."

msgid "Client"
msgstr "לָקוּחַ"

msgid "User"
msgstr "מִשׁתַמֵשׁ"

msgid "Scopes"
msgstr "טווחים"

msgid "Created"
msgstr "נוצר"

msgid "Access Token Expires"
msgstr "תוקף אסימון הגישה פג"

msgid "Refresh Token Expires"
msgstr "תוקף אסימון הרענון פג"

msgid "Actions"
msgstr "פעולות"

msgid "No active tokens found."
msgstr "לא נמצאו אסימונים פעילים."

msgid "Expired"
msgstr "פג תוקף"

msgid "N/A"
msgstr "לא רלוונטי"

msgid "Are you sure you want to revoke this token?"
msgstr "האם אתה בטוח שאתה רוצה לבטל את האסימון הזה?"

msgid "Revoke"
msgstr "לְבַטֵל"

msgid "Authorization Request"
msgstr "בקשת אישור"

msgid "is requesting access to your account"
msgstr "מבקש גישה לחשבונך"

msgid "This will allow the application to:"
msgstr "זה יאפשר לאפליקציה:"

msgid "Deny"
msgstr "לְהַכּחִישׁ"

msgid "Approve"
msgstr "לְאַשֵׁר"

msgid "Only approve if you trust this application. It will have access to your account data based on the permissions above."
msgstr "אשר רק אם אתה סומך על אפליקציה זו. תהיה לה גישה לנתוני החשבון שלך בהתבסס על ההרשאות לעיל."

msgid "Read your posts and content"
msgstr "קרא את הפוסטים והתוכן שלך"

msgid "Create and modify posts"
msgstr "יצירה ושינוי של פוסטים"

msgid "Delete posts"
msgstr "מחיקת פוסטים"

msgid "Authorization Successful"
msgstr "האישור הצליח"

msgid "Copy this authorization code and paste it back to the AI application:"
msgstr "העתק את קוד ההרשאה הזה והדבק אותו בחזרה לאפליקציית הבינה המלאכותית:"

msgid "Authorization Code"
msgstr "קוד אישור"

msgid "Copy Code"
msgstr "העתקת קוד"

msgid "Code copied to clipboard!"
msgstr "קוד הועתק ללוח!"

msgid "Important:"
msgstr "חָשׁוּב:"

msgid "This code expires in 10 minutes and can only be used once."
msgstr "קוד זה פג תוקף בעוד 10 דקות וניתן להשתמש בו פעם אחת בלבד."

