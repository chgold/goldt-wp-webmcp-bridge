# Translation file
msgid ""
msgstr ""
"Content-Type: text/plain; charset=UTF-8\n"
"Content-Transfer-Encoding: 8bit\n"

msgid "AI Connect"
msgstr "בינה מלאכותית קונקט"

msgid "https://github.com/chgold/goldt-webmcp-bridge"
msgstr "https://github.com/chgold/goldt-webmcp-bridge"

msgid "Bridge WordPress & AI Agents with WebMCP Protocol"
msgstr "גישור בין סוכני WordPress ובינה מלאכותית לבין פרוטוקול WebMCP"

msgid "chgold"
msgstr "chgold"

msgid "https://github.com/chgold"
msgstr "https://github.com/chgold"

msgid "AI Connect: Missing dependencies. Please run \\"composer install\\" in the plugin directory."
msgstr "AI Connect: תלויות חסרות. אנא הפעל את \\"composer install\\" בספריית התוספים."

msgid "AI Connect: WooCommerce is recommended for full functionality."
msgstr "AI Connect: מומלץ להשתמש ב-WooCommerce לפונקציונליות מלאה."

msgid "Settings"
msgstr "הגדרות"

msgid "✅ AI Connect v%s is active and ready!"
msgstr "✅ AI Connect v%s פעיל ומוכן!"

msgid "Environment Status"
msgstr "מצב סביבתי"

msgid "⚠️ Action Required"
msgstr "⚠️ נדרשת פעולה"

msgid "Composer dependencies are not installed. Please run:"
msgstr "תלויות Composer אינן מותקנות. אנא הפעל:"

msgid "🎯 Quick Start"
msgstr "🎯 התחלה מהירה"

msgid "Test the API"
msgstr "בדיקת ה-API"

msgid "View Manifest"
msgstr "הצג מניפסט"

msgid "Authentication"
msgstr "אימות"

msgid "Use WordPress username & password to login via"
msgstr "השתמשו בשם המשתמש והסיסמה של WordPress כדי להתחבר דרך"

msgid "Available Tools"
msgstr "כלים זמינים"

msgid "5 WordPress core tools (searchPosts, getPost, searchPages, getPage, getCurrentUser)"
msgstr "5 כלי ליבה של WordPress (searchPosts, getPost, searchPages, getPage, getCurrentUser)"

msgid "Documentation"
msgstr "תיעוד"

msgid "GitHub README"
msgstr "קובץ README של גיטהאב"

msgid "User access revoked successfully."
msgstr "גישת המשתמש בוטלה בהצלחה."

msgid "User access restored successfully."
msgstr "גישת המשתמש שוחזרה בהצלחה."

msgid "JWT Secret rotated successfully! All existing tokens have been invalidated."
msgstr "סוד JWT הסתובב בהצלחה! כל האסימונים הקיימים בוטלו."

msgid "Settings saved!"
msgstr "ההגדרות נשמרו!"

msgid "API Rate Limiting"
msgstr "הגבלת קצב API"

msgid "Rate Limit (per minute)"
msgstr "מגבלת קצב (לדקה)"

msgid "Maximum API requests per minute per user"
msgstr "מקסימום בקשות API לדקה למשתמש"

msgid "Rate Limit (per hour)"
msgstr "מגבלת תעריף (לשעה)"

msgid "Maximum API requests per hour per user"
msgstr "מקסימום בקשות API לשעה למשתמש"

msgid "Data Management"
msgstr "ניהול נתונים"

msgid "Uninstall Cleanup"
msgstr "ניקוי ההתקנה"

msgid "Delete all plugin data when uninstalling"
msgstr "מחיקת כל נתוני התוסף בעת הסרת ההתקנה"

msgid "When enabled, all OAuth clients, tokens, and settings will be permanently deleted when you uninstall this plugin. Leave unchecked to preserve data for reinstallation."
msgstr "כאשר אפשרות זו מופעלת, כל לקוחות, טוקנים והגדרות OAuth יימחקו לצמיתות לאחר הסרת התוסף. השאר את האפשרות לא מסומנת כדי לשמור נתונים להתקנה מחדש."

msgid "Note:"
msgstr "פֶּתֶק:"

msgid "Sensitive security data (JWT secrets, refresh tokens) will always be deleted regardless of this setting."
msgstr "נתוני אבטחה רגישים (סודות JWT, אסימוני רענון) יימחקו תמיד ללא קשר להגדרה זו."

msgid "Save Settings"
msgstr "שמור הגדרות"

msgid "Security"
msgstr "בִּטָחוֹן"

msgid "Rotate JWT Secret Key"
msgstr "סיבוב מפתח סודי של JWT"

msgid "This will generate a new JWT secret key and <strong>immediately invalidate all existing access tokens</strong>."
msgstr "פעולה זו תיצור מפתח סודי JWT חדש ותבטל <strong>באופן מיידי את כל אסימוני הגישה הקיימים</strong> ."

msgid "All users will need to authenticate again to get new tokens."
msgstr "כל המשתמשים יצטרכו לאמת שוב כדי לקבל אסימונים חדשים."

msgid "Warning:"
msgstr "אַזהָרָה:"

msgid "This action cannot be undone. All AI agents currently connected will be disconnected."
msgstr "לא ניתן לבטל פעולה זו. כל סוכני הבינה המלאכותית המחוברים כעת ינותקו."

msgid "Are you sure you want to rotate the JWT secret? This will disconnect all connected AI agents and users will need to re-authenticate."
msgstr "האם אתה בטוח שברצונך לסובב את סוד ה-JWT? פעולה זו תנתק את כל סוכני הבינה המלאכותית המחוברים והמשתמשים יצטרכו לאמת מחדש."

msgid "Rotate JWT Secret"
msgstr "סובב את סוד JWT"

msgid "Manage User Access"
msgstr "ניהול גישת משתמש"

msgid "Block specific users from accessing AI Connect. Blocked users cannot authenticate or use existing tokens."
msgstr "חסום משתמשים ספציפיים מגישה ל-AI Connect. משתמשים חסומים אינם יכולים לאמת או להשתמש באסימונים קיימים."

msgid "Blocked Users"
msgstr "משתמשים חסומים"

msgid "User ID"
msgstr "מזהה משתמש"

msgid "Username"
msgstr "שם משתמש"

msgid "Email"
msgstr "אֶלֶקטרוֹנִי"

msgid "Action"
msgstr "פְּעוּלָה"

msgid "Restore Access"
msgstr "שחזור גישה"

msgid "No users are currently blocked."
msgstr "אין משתמשים חסומים כרגע."

msgid "Block a User"
msgstr "חסימת משתמש"

msgid "User ID:"
msgstr "מזהה משתמש:"

msgid "Enter the WordPress user ID to block"
msgstr "הזן את שם המשתמש של WordPress כדי לחסום"

msgid "Block User"
msgstr "חסימת משתמש"

