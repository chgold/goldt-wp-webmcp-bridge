msgstr "ID de Usuario"

msgid "Username"
msgstr "Nombre de usuario"

msgid "Email"
msgstr "Correo electrónico"

msgid "Action"
msgstr "Acción"

msgid "Restore Access"
msgstr "Restaurar Acceso"

msgid "No users are currently blocked."
msgstr "Actualmente no hay usuarios bloqueados."

msgid "Block a User"
msgstr "Bloquear a un usuario"

msgid "User ID:"
msgstr "ID de usuario:"

msgid "Enter the WordPress user ID to block"
msgstr "Introduzca el ID de usuario de WordPress para bloquear"

msgid "Block User"
msgstr "Bloquear"

