# Translation file
msgid ""
msgstr ""
"Content-Type: text/plain; charset=UTF-8\n"
"Content-Transfer-Encoding: 8bit\n"

msgid "AI Connect"
msgstr "AI Connect"

msgid "https://github.com/chgold/goldt-wp-webmcp-bridge"
msgstr "https://github.com/chgold/goldt-wp-webmcp-bridge"

msgid "Bridge WordPress & AI Agents with WebMCP Protocol"
msgstr "Объедините WordPress и ИИ-агентов с помощью протокола WebMCP."

msgid "chgold"
msgstr "chgold"

msgid "https://github.com/chgold"
msgstr "https://github.com/chgold"

msgid "AI Connect: Missing dependencies. Please run \\"composer install\\" in the plugin directory."
msgstr "AI Connect: Отсутствуют зависимости. Пожалуйста, выполните команду \\"composer install\\" в каталоге плагина."

msgid "AI Connect: WooCommerce is recommended for full functionality."
msgstr "AI Connect: Для обеспечения полной функциональности рекомендуется использовать WooCommerce."

msgid "Settings"
msgstr "Настройки"

msgid "✅ AI Connect v%s is active and ready!"
msgstr "✅ AI Connect v%s активирован и готов к работе!"

msgid "Environment Status"
msgstr "Состояние окружающей среды"

msgid "⚠️ Action Required"
msgstr "⚠️ Требуются действия"

msgid "Composer dependencies are not installed. Please run:"
msgstr "Зависимости Composer не установлены. Пожалуйста, выполните:"

msgid "🎯 Quick Start"
msgstr "🎯 Быстрый старт"

msgid "Test the API"
msgstr "Протестируйте API"

msgid "View Manifest"
msgstr "Просмотреть манифест"

msgid "Authentication"
msgstr "Аутентификация"

msgid "Use WordPress username & password to login via"
msgstr "Для входа используйте имя пользователя и пароль WordPress."

msgid "Available Tools"
msgstr "Доступные инструменты"

msgid "5 WordPress core tools (searchPosts, getPost, searchPages, getPage, getCurrentUser)"
msgstr "5 основных инструментов WordPress (searchPosts, getPost, searchPages, getPage, getCurrentUser)"

msgid "Documentation"
msgstr "Документация"

msgid "GitHub README"
msgstr "Файл README на GitHub"

msgid "User access revoked successfully."
msgstr "Доступ пользователя успешно отозван."

msgid "User access restored successfully."
msgstr "Доступ пользователя успешно восстановлен."

msgid "JWT Secret rotated successfully! All existing tokens have been invalidated."
msgstr "JWT Secret успешно прошёл ротацию! Все существующие токены аннулированы."

msgid "Settings saved!"
msgstr "Настройки сохранены!"

msgid "API Rate Limiting"
msgstr "Ограничение скорости запросов к API"

msgid "Rate Limit (per minute)"
msgstr "Лимит скорости (в минуту)"

msgid "Maximum API requests per minute per user"
msgstr "Максимальное количество запросов к API в минуту на одного пользователя"

msgid "Rate Limit (per hour)"
msgstr "Ограничение скорости (в час)"

msgid "Maximum API requests per hour per user"
msgstr "Максимальное количество запросов к API в час на одного пользователя"

msgid "Data Management"
msgstr "Управление данными"

msgid "Uninstall Cleanup"
msgstr "Удаление и очистка"

msgid "Delete all plugin data when uninstalling"
msgstr "При удалении плагина необходимо удалить все его данные."

msgid "When enabled, all OAuth clients, tokens, and settings will be permanently deleted when you uninstall this plugin. Leave unchecked to preserve data for reinstallation."
msgstr "При включении этой опции все клиенты OAuth, токены и настройки будут безвозвратно удалены при деинсталляции плагина. Оставьте флажок снятым, чтобы сохранить данные для повторной установки."

msgid "Note:"
msgstr "Примечание:"

msgid "Sensitive security data (JWT secrets, refresh tokens) will always be deleted regardless of this setting."
msgstr "Конфиденциальные данные безопасности (секретные JWT-токены, токены обновления) всегда будут удаляться независимо от этой настройки."

msgid "Save Settings"
msgstr "Сохраните настройки"

msgid "Security"
msgstr "Безопасность"

msgid "Rotate JWT Secret Key"
msgstr "Поворот секретного ключа JWT"

msgid "This will generate a new JWT secret key and <strong>immediately invalidate all existing access tokens</strong>."
msgstr "Это сгенерирует новый секретный ключ JWT и <strong>немедленно аннулирует все существующие токены доступа</strong> ."

msgid "All users will need to authenticate again to get new tokens."
msgstr "Всем пользователям потребуется повторно пройти аутентификацию для получения новых токенов."

msgid "Warning:"
msgstr "Предупреждение:"

msgid "This action cannot be undone. All AI agents currently connected will be disconnected."
msgstr "Это действие необратимо. Все подключенные в данный момент агенты ИИ будут отключены."

msgid "Are you sure you want to rotate the JWT secret? This will disconnect all connected AI agents and users will need to re-authenticate."
msgstr "Вы уверены, что хотите повернуть секретный ключ JWT? Это отключит всех подключенных агентов ИИ, и пользователям потребуется пройти повторную аутентификацию."

msgid "Rotate JWT Secret"
msgstr "Повернуть секрет JWT"

msgid "Manage User Access"
msgstr "Управление доступом пользователей"

msgid "Block specific users from accessing AI Connect. Blocked users cannot authenticate or use existing tokens."
msgstr "Заблокируйте доступ к AI Connect для определенных пользователей. Заблокированные пользователи не смогут пройти аутентификацию или использовать имеющиеся токены."

msgid "Blocked Users"
msgstr "Заблокированные пользователи"

msgid "User ID"
msgstr "ID пользователя"

msgid "Username"
msgstr "Имя пользователя"

msgid "Email"
msgstr "Электронная почта"

msgid "Action"
msgstr "Действие"

msgid "Restore Access"
msgstr "Восстановить доступ"

msgid "No users are currently blocked."
msgstr "В данный момент ни один пользователь не заблокирован."

msgid "Block a User"
msgstr "Заблокировать пользователя"

msgid "User ID:"
msgstr "ID пользователя:"

msgid "Enter the WordPress user ID to block"
msgstr "Введите идентификатор пользователя WordPress, чтобы заблокировать"

msgid "Block User"
msgstr "Заблокировать пользователя"

