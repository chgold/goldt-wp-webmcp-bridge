msgid "GoldT WebMCP Bridge"
msgstr "Мост GoldT WebMCP"

msgid "Bridge for 8 AI agents (Claude, ChatGPT, Grok, more) via WebMCP with OAuth 2.0"
msgstr "Мост для 8 агентов ИИ (Claude, ChatGPT, Grok и другие) через WebMCP с OAuth 2.0"

msgid "chgold"
msgstr "chgold"

msgid "https://github.com/chgold"
msgstr "https://github.com/chgold"

msgid "GoldT WebMCP Bridge: Missing dependencies. Please run \"composer install\" in the plugin directory."
msgstr "GoldT WebMCP Bridge: Отсутствуют зависимости. Пожалуйста, выполните команду \"composer install\" в каталоге плагина."

msgid "GoldT WebMCP Bridge: WooCommerce is recommended for full functionality."
msgstr "GoldT WebMCP Bridge: для обеспечения полной функциональности рекомендуется использовать WooCommerce."

msgid "Settings"
msgstr "Настройки"

msgid "AI Connect"
msgstr "AI Connect"

msgid "✅ AI Connect v%s is active and ready!"
msgstr "✅ AI Connect v%s активирован и готов к работе!"

msgid "Environment Status"
msgstr "Состояние окружающей среды"

msgid "Dependencies Missing"
msgstr "Отсутствуют зависимости"

msgid "Run the following command in the plugin directory:"
msgstr "Выполните следующую команду в каталоге плагина:"

msgid "User access revoked successfully."
msgstr "Доступ пользователя успешно отозван."

msgid "User access restored successfully."
msgstr "Доступ пользователя успешно восстановлен."

msgid "JWT Secret rotated successfully! All existing tokens have been invalidated."
msgstr "JWT Secret успешно прошёл ротацию! Все существующие токены аннулированы."

msgid "Settings saved!"
msgstr "Настройки сохранены!"

msgid "API Rate Limiting"
msgstr "Ограничение скорости запросов к API"

msgid "Rate Limit (per minute)"
msgstr "Лимит скорости (в минуту)"

msgid "Maximum API requests per minute per user"
msgstr "Максимальное количество запросов к API в минуту на одного пользователя"

msgid "Rate Limit (per hour)"
msgstr "Ограничение скорости (в час)"

msgid "Maximum API requests per hour per user"
msgstr "Максимальное количество запросов к API в час на одного пользователя"

msgid "Data Management"
msgstr "Управление данными"

msgid "Uninstall Cleanup"
msgstr "Удаление и очистка"

msgid "Delete all plugin data when uninstalling"
msgstr "При удалении плагина необходимо удалить все его данные."

msgid "When enabled, all OAuth clients, tokens, and settings will be permanently deleted when you uninstall this plugin. Leave unchecked to preserve data for reinstallation."
msgstr "При включении этой опции все клиенты OAuth, токены и настройки будут безвозвратно удалены при деинсталляции плагина. Оставьте флажок снятым, чтобы сохранить данные для повторной установки."

msgid "Note:"
msgstr "Примечание:"

msgid "Sensitive security data (JWT secrets, refresh tokens) will always be deleted regardless of this setting."
msgstr "Конфиденциальные данные безопасности (секретные JWT-токены, токены обновления) всегда будут удаляться независимо от этой настройки."

msgid "Save Settings"
msgstr "Сохраните настройки"

msgid "Security"
msgstr "Безопасность"

msgid "Rotate JWT Secret Key"
msgstr "Поворот секретного ключа JWT"

msgid "This will generate a new JWT secret key and <strong>immediately invalidate all existing access tokens</strong>."
msgstr "Это сгенерирует новый секретный ключ JWT и <strong>немедленно аннулирует все существующие токены доступа</strong> ."

msgid "All users will need to authenticate again to get new tokens."
msgstr "Всем пользователям потребуется повторно пройти аутентификацию для получения новых токенов."

msgid "Warning:"
msgstr "Предупреждение:"

msgid "This action cannot be undone. All AI agents currently connected will be disconnected."
msgstr "Это действие необратимо. Все подключенные в данный момент агенты ИИ будут отключены."

msgid "Are you sure you want to rotate the JWT secret? This will disconnect all connected AI agents and users will need to re-authenticate."
msgstr "Вы уверены, что хотите повернуть секретный ключ JWT? Это отключит всех подключенных агентов ИИ, и пользователям потребуется пройти повторную аутентификацию."

msgid "Rotate JWT Secret"
msgstr "Повернуть секрет JWT"

msgid "Manage User Access"
msgstr "Управление доступом пользователей"

msgid "Block specific users from accessing AI Connect. Blocked users cannot authenticate or use existing tokens."
msgstr "Заблокируйте доступ к AI Connect для определенных пользователей. Заблокированные пользователи не смогут пройти аутентификацию или использовать имеющиеся токены."

msgid "Blocked Users"
msgstr "Заблокированные пользователи"

msgid "User ID"
msgstr "ID пользователя"

msgid "Username"
msgstr "Имя пользователя"

msgid "Email"
msgstr "Электронная почта"

msgid "Action"
msgstr "Действие"

msgid "Restore Access"
msgstr "Восстановить доступ"

msgid "No users are currently blocked."
msgstr "В данный момент ни один пользователь не заблокирован."

msgid "Block a User"
msgstr "Заблокировать пользователя"

msgid "User ID:"
msgstr "ID пользователя:"

msgid "Enter the WordPress user ID to block"
msgstr "Введите идентификатор пользователя WordPress, чтобы заблокировать"

msgid "Block User"
msgstr "Заблокировать пользователя"

msgid "OAuth Tokens"
msgstr "Токены OAuth"

msgid "Token revoked successfully."
msgstr "Токен успешно отозван."

msgid "Read content"
msgstr "Читать контент"

msgid "Read posts, pages, and other content"
msgstr "Читайте посты, страницы и другой контент."

msgid "Write content"
msgstr "Напишите контент"

msgid "Create and update posts and pages"
msgstr "Создавайте и обновляйте записи и страницы."

msgid "Delete content"
msgstr "Удалить контент"

msgid "Delete posts and pages"
msgstr "Удалить записи и страницы"

msgid "Manage users"
msgstr "Управление пользователями"

msgid "View and manage user accounts"
msgstr "Просмотр и управление учетными записями пользователей."

msgid "OAuth Access Tokens"
msgstr "Токены доступа OAuth"

msgid "Manage OAuth access tokens that have been granted to AI applications."
msgstr "Управление токенами доступа OAuth, предоставленными приложениям искусственного интеллекта."

msgid "Client"
msgstr "Клиент"

msgid "User"
msgstr "Пользователь"

msgid "Scopes"
msgstr "Области применения"

msgid "Created"
msgstr "Созданный"

msgid "Access Token Expires"
msgstr "Срок действия токена доступа истекает."

msgid "Refresh Token Expires"
msgstr "Срок действия токена обновления истекает."

msgid "Actions"
msgstr "Действия"

msgid "No active tokens found."
msgstr "Активных токенов не найдено."

msgid "Expired"
msgstr "Истекший"

msgid "N/A"
msgstr "Н/Д"

msgid "Are you sure you want to revoke this token?"
msgstr "Вы уверены, что хотите отозвать этот токен?"

msgid "Revoke"
msgstr "Отменить"

msgid "Authorization Request"
msgstr "Запрос на авторизацию"

msgid "is requesting access to your account"
msgstr "запрашивает доступ к вашей учетной записи"

msgid "This will allow the application to:"
msgstr "Это позволит приложению:"

msgid "Deny"
msgstr "Отрицать"

msgid "Approve"
msgstr "Утвердить"

msgid "Only approve if you trust this application. It will have access to your account data based on the permissions above."
msgstr "Одобряйте только в том случае, если вы доверяете этому приложению. Оно получит доступ к данным вашей учетной записи на основании указанных выше разрешений."

msgid "Read your posts and content"
msgstr "Читайте ваши публикации и контент."

msgid "Create and modify posts"
msgstr "Создание и изменение записей"

msgid "Delete posts"
msgstr "Удалить сообщения"

msgid "Authorization Successful"
msgstr "Авторизация прошла успешно."

msgid "Copy this authorization code and paste it back to the AI application:"
msgstr "Скопируйте этот код авторизации и вставьте его обратно в приложение ИИ:"

msgid "Authorization Code"
msgstr "Код авторизации"

msgid "Copy Code"
msgstr "Скопировать код"

msgid "Code copied to clipboard!"
msgstr "Код скопирован в буфер обмена!"

msgid "Important:"
msgstr "Важный:"

msgid "This code expires in 10 minutes and can only be used once."
msgstr "Срок действия этого кода истекает через 10 минут, и его можно использовать только один раз."

