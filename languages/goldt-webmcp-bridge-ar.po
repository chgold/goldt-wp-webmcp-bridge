msgid "GoldT WebMCP Bridge"
msgstr "جسر GoldT WebMCP"

msgid "Bridge for 8 AI agents (Claude, ChatGPT, Grok, more) via WebMCP with OAuth 2.0"
msgstr "جسر لثمانية وكلاء ذكاء اصطناعي (كلود، تشات جي بي تي، جروك، وغيرهم) عبر WebMCP باستخدام OAuth 2.0"

msgid "chgold"
msgstr "chgold"

msgid "https://github.com/chgold"
msgstr "https://github.com/chgold"

msgid "GoldT WebMCP Bridge: Missing dependencies. Please run \"composer install\" in the plugin directory."
msgstr "جسر GoldT WebMCP: هناك تبعيات مفقودة. يرجى تشغيل \"composer install\" في مجلد الإضافة."

msgid "GoldT WebMCP Bridge: WooCommerce is recommended for full functionality."
msgstr "جسر GoldT WebMCP: يُنصح باستخدام WooCommerce للحصول على وظائف كاملة."

msgid "Settings"
msgstr "الإعدادات"

msgid "AI Connect"
msgstr "اتصال الذكاء الاصطناعي"

msgid "✅ AI Connect v%s is active and ready!"
msgstr "✅ AI Connect v%s نشط وجاهز!"

msgid "Environment Status"
msgstr "حالة البيئة"

msgid "Dependencies Missing"
msgstr "التبعيات مفقودة"

msgid "Run the following command in the plugin directory:"
msgstr "قم بتشغيل الأمر التالي في مجلد الإضافة:"

msgid "User access revoked successfully."
msgstr "تم إبطال وصول المستخدم بنجاح."

msgid "User access restored successfully."
msgstr "تمت استعادة وصول المستخدم بنجاح."

msgid "JWT Secret rotated successfully! All existing tokens have been invalidated."
msgstr "تم تدوير JWT Secret بنجاح! تم إبطال جميع الرموز المميزة الموجودة."

msgid "Settings saved!"
msgstr "تم حفظ الإعدادات!"

msgid "API Rate Limiting"
msgstr "تحديد المعدّل"

msgid "Rate Limit (per minute)"
msgstr "حد السعر (لكل دقيقة)"

msgid "Maximum API requests per minute per user"
msgstr "الحد الأقصى لطلبات واجهة برمجة التطبيقات في الدقيقة لكل مستخدم"

msgid "Rate Limit (per hour)"
msgstr "حد السعر (لكل ساعة)"

msgid "Maximum API requests per hour per user"
msgstr "الحد الأقصى لطلبات واجهة برمجة التطبيقات في الساعة لكل مستخدم"

msgid "Data Management"
msgstr "إدارة البيانات"

msgid "Uninstall Cleanup"
msgstr "إلغاء تثبيت التنظيف"

msgid "Delete all plugin data when uninstalling"
msgstr "حذف جميع بيانات المكون الإضافي عند إلغاء التثبيت"

msgid "When enabled, all OAuth clients, tokens, and settings will be permanently deleted when you uninstall this plugin. Leave unchecked to preserve data for reinstallation."
msgstr "عند التمكين، سيتم حذف جميع عملاء OAuth والرموز المميزة والإعدادات نهائيًا عند إلغاء تثبيت هذا المكون الإضافي. اتركه دون تحديد للحفاظ على البيانات لإعادة تثبيتها."

msgid "Note:"
msgstr "ملاحظة:"

msgid "Sensitive security data (JWT secrets, refresh tokens) will always be deleted regardless of this setting."
msgstr "سيتم دائمًا حذف بيانات الأمان الحساسة (أسرار JWT، رموز التحديث) بغض النظر عن هذا الإعداد."

msgid "Save Settings"
msgstr "احفظ التغييرات"

msgid "Security"
msgstr "الضمان"

msgid "Rotate JWT Secret Key"
msgstr "تدوير المفتاح السري JWT"

msgid "This will generate a new JWT secret key and <strong>immediately invalidate all existing access tokens</strong>."
msgstr "سيؤدي هذا إلى إنشاء مفتاح سري جديد لـ JWT <strong>وإبطال جميع رموز الوصول الحالية على الفور</strong>."

msgid "All users will need to authenticate again to get new tokens."
msgstr "سيحتاج جميع المستخدمين إلى المصادقة مرة أخرى للحصول على رموز جديدة."

msgid "Warning:"
msgstr "تحذير :"

msgid "This action cannot be undone. All AI agents currently connected will be disconnected."
msgstr "لا يمكن التراجع عن هذا الإجراء. سيتم فصل جميع وكلاء الذكاء الاصطناعي المتصلين حاليًا."

msgid "Are you sure you want to rotate the JWT secret? This will disconnect all connected AI agents and users will need to re-authenticate."
msgstr "هل أنت متأكد أنك تريد تدوير سر JWT ؟ سيؤدي هذا إلى فصل جميع وكلاء الذكاء الاصطناعي المتصلين وسيحتاج المستخدمون إلى إعادة المصادقة."

msgid "Rotate JWT Secret"
msgstr "تدوير سر JWT"

msgid "Manage User Access"
msgstr "إدارة وصول المستخدم"

msgid "Block specific users from accessing AI Connect. Blocked users cannot authenticate or use existing tokens."
msgstr "حظر مستخدمين محددين من الوصول إلى AI Connect. لا يمكن للمستخدمين المحظورين مصادقة أو استخدام الرموز المميزة الموجودة."

msgid "Blocked Users"
msgstr "قائمة الحظر"

msgid "User ID"
msgstr "معرّف المستخدم"

msgid "Username"
msgstr "[ترجمة المصطلح: Username]"

msgid "Email"
msgstr "البريد الإلكتروني:"

msgid "Action"
msgstr "الإجراء"

msgid "Restore Access"
msgstr "استعادة الوصول"

msgid "No users are currently blocked."
msgstr "لا يوجد مستخدمون محظورون حاليًا."

msgid "Block a User"
msgstr "المبنى أ"

msgid "User ID:"
msgstr "كود المستخدم:"

msgid "Enter the WordPress user ID to block"
msgstr "أدخل معرف مستخدم وردبرس لحظره"

msgid "Block User"
msgstr "مسدود کردن کاربر"

msgid "OAuth Tokens"
msgstr "رموز OAuth"

msgid "Token revoked successfully."
msgstr "تم إلغاء الرمز بنجاح."

msgid "Read content"
msgstr "اقرأ المحتوى"

msgid "Read posts, pages, and other content"
msgstr "اقرأ المنشورات والصفحات والمحتويات الأخرى"

msgid "Write content"
msgstr "كتابة المحتوى"

msgid "Create and update posts and pages"
msgstr "إنشاء وتحديث المنشورات والصفحات"

msgid "Delete content"
msgstr "حذف المحتوى"

msgid "Delete posts and pages"
msgstr "حذف المنشورات والصفحات"

msgid "Manage users"
msgstr "إدارة المستخدمين"

msgid "View and manage user accounts"
msgstr "عرض وإدارة حسابات المستخدمين"

msgid "OAuth Access Tokens"
msgstr "رموز الوصول OAuth"

msgid "Manage OAuth access tokens that have been granted to AI applications."
msgstr "إدارة رموز الوصول OAuth الممنوحة لتطبيقات الذكاء الاصطناعي."

msgid "Client"
msgstr "عميل"

msgid "User"
msgstr "مستخدم"

msgid "Scopes"
msgstr "النطاقات"

msgid "Created"
msgstr "مخلوق"

msgid "Access Token Expires"
msgstr "تنتهي صلاحية رمز الوصول"

msgid "Refresh Token Expires"
msgstr "تنتهي صلاحية رمز التحديث"

msgid "Actions"
msgstr "الإجراءات"

msgid "No active tokens found."
msgstr "لم يتم العثور على أي رموز نشطة."

msgid "Expired"
msgstr "منتهي الصلاحية"

msgid "N/A"
msgstr "غير متوفر"

msgid "Are you sure you want to revoke this token?"
msgstr "هل أنت متأكد من رغبتك في إلغاء هذا الرمز المميز؟"

msgid "Revoke"
msgstr "إلغاء"

msgid "Authorization Request"
msgstr "طلب تفويض"

msgid "is requesting access to your account"
msgstr "يطلب الوصول إلى حسابك"

msgid "This will allow the application to:"
msgstr "سيسمح هذا للتطبيق بما يلي:"

msgid "Deny"
msgstr "ينكر"

msgid "Approve"
msgstr "يعتمد"

msgid "Only approve if you trust this application. It will have access to your account data based on the permissions above."
msgstr "لا توافق إلا إذا كنت تثق بهذا التطبيق. سيتمكن التطبيق من الوصول إلى بيانات حسابك بناءً على الأذونات المذكورة أعلاه."

msgid "Read your posts and content"
msgstr "اقرأ منشوراتك ومحتواك"

msgid "Create and modify posts"
msgstr "إنشاء وتعديل المنشورات"

msgid "Delete posts"
msgstr "حذف المنشورات"

msgid "Authorization Successful"
msgstr "تمت الموافقة بنجاح"

msgid "Copy this authorization code and paste it back to the AI application:"
msgstr "انسخ رمز التفويض هذا والصقه مرة أخرى في تطبيق الذكاء الاصطناعي:"

msgid "Authorization Code"
msgstr "رمز التفويض"

msgid "Copy Code"
msgstr "انسخ الكود"

msgid "Code copied to clipboard!"
msgstr "تم نسخ الكود إلى الحافظة!"

msgid "Important:"
msgstr "مهم:"

msgid "This code expires in 10 minutes and can only be used once."
msgstr "ينتهي صلاحية هذا الرمز خلال 10 دقائق ولا يمكن استخدامه إلا مرة واحدة."

