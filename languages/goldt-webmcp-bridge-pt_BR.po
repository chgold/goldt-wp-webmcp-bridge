msgstr "Copiar código"

msgid "Code copied to clipboard!"
msgstr "Código copiado para a área de transferência!"

msgid "Important:"
msgstr "Importante:"

msgid "This code expires in 10 minutes and can only be used once."
msgstr "Este código expira em 10 minutos e só pode ser usado uma vez."

