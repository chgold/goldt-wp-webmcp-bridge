msgstr "Faça a ponte entre o WordPress e os agentes de IA com o protocolo WebMCP"

msgid "chgold"
msgstr "chgold"

msgid "https://github.com/chgold"
msgstr "https://github.com/chgold"

msgid "AI Connect: Missing dependencies. Please run \\"composer install\\" in the plugin directory."
msgstr "AI Connect: Dependências ausentes. Execute \\"composer install\\" no diretório do plugin."

msgid "AI Connect: WooCommerce is recommended for full functionality."
msgstr "AI Connect: O WooCommerce é recomendado para funcionalidade completa."

