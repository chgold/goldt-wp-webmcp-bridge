msgstr "Criar e atualizar posts e páginas"

msgid "Delete content"
msgstr "Excluir conteúdo"

msgid "Delete posts and pages"
msgstr "Excluir publicações e páginas"

msgid "Manage users"
msgstr "Gerenciar usuários"

msgid "View and manage user accounts"
msgstr "Visualizar e gerenciar contas de usuário"

msgid "OAuth Access Tokens"
msgstr "Tokens de acesso OAuth"

msgid "Manage OAuth access tokens that have been granted to AI applications."
msgstr "Gerenciar tokens de acesso OAuth concedidos a aplicativos de IA."

