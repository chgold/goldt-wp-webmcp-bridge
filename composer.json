{
    "name": "goldt/webmcp-bridge",
    "description": "Bridge for 8 AI agents (Claude, ChatGPT, Grok, more) via WebMCP with OAuth 2.0 - WordPress plugin",
    "type": "wordpress-plugin",
    "keywords": [
        "wordpress",
        "ai",
        "webmcp",
        "mcp",
        "oauth",
        "oauth2",
        "api",
        "woocommerce",
        "automation",
        "agent",
        "llm",
        "claude",
        "chatgpt",
        "gemini",
        "grok",
        "perplexity"
    ],
    "license": "GPL-3.0-or-later",
    "authors": [
        {
            "name": "chgold",
            "role": "Developer"
        }
    ],
    "require": {
        "php": ">=7.4",
        "predis/predis": "^3.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.0"
    },
    "autoload": {
        "psr-4": {
            "GoldtWebMCP\\": "includes/",
            "GoldtWebMCP\\Core\\": "includes/core/",
            "GoldtWebMCP\\Modules\\": "includes/modules/",
            "GoldtWebMCP\\API\\": "includes/api/",
            "GoldtWebMCP\\OAuth\\": "includes/oauth/"
        }
    },
    "config": {
        "platform": {
            "php": "7.4"
        },
        "optimize-autoloader": true,
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
